diff --git a/xls/scheduling/scheduling_options.h b/xls/scheduling/scheduling_options.h
index 9e210997c..19ffd6fcd 100644
--- a/xls/scheduling/scheduling_options.h
+++ b/xls/scheduling/scheduling_options.h
@@ -69,6 +69,39 @@ enum class SchedulingStrategy : int8_t {
   // Seed from a legal schedule and apply heuristic local-search refinements to
   // reduce register pressure while preserving legality and timing.
   HEURISTIC,
+
+  // Iteration-1 heuristic variant. Uses an ASAP/ALAP-derived list scheduler
+  // instead of SDC, prioritizing low-mobility nodes with high reverse-path
+  // delay and fanout so timing-critical work is pulled forward before stage
+  // slack is consumed.
+  ITER_1,
+
+  // Iteration-2 heuristic variant. Starts from a legal seed schedule and
+  // prioritizes later moves on stage-tail nodes in slow stages, biasing toward
+  // high tail-delay relief per carried operand bit and rewarding fanout that
+  // is concentrated in the immediate downstream stage so timing can improve
+  // without stretching live ranges across deeper pipeline stages.
+  ITER_2,
+
+  // Iteration-3 heuristic variant. Prioritizes expensive critical-path tail
+  // nodes whose outputs already cross a stage boundary, using a
+  // boundary-leverage density score to target performance bottlenecks whose
+  // downstream fanout is already concentrated near the new boundary so timing
+  // can improve with lower collateral register pressure.
+  ITER_3,
+
+  // Iteration-4 heuristic variant. Targets critical-path tail nodes in the
+  // slowest stage that are already pulled toward the next boundary, preferring
+  // later moves whose fanout is concentrated just across that boundary so
+  // timing bottlenecks can be split with less duplicated live-range pressure.
+  ITER_4,
+
+  // Iteration-5 heuristic variant. Targets critical-path tail nodes in the
+  // slowest stage whose fanout is concentrated in the immediate downstream
+  // stage, using a boundary-containment density score to favor later boundary
+  // splits that improve timing without spreading duplicated live ranges deeper
+  // into the pipeline.
+  ITER_5,
 };
 
